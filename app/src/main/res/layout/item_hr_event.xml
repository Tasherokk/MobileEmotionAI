<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardView"
    style="@style/ModernCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/badgeActive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_status_badge"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="ACTIVE"/>

        <TextView
            android:id="@+id/tvTitle"
            style="@style/TextAppearance.EmotionsAi.CardTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/badgeActive"
            tools:text="Annual Team Building 2024"/>

        <LinearLayout
            android:id="@+id/infoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:id="@+id/ivCompany"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_business"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvCompany"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    tools:text="Google LLC"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <ImageView
                    android:id="@+id/ivCalendar"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_calendar_v"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvDates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    tools:text="Jan 15 - Jan 18, 2024"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:id="@+id/ivParticipants"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_groups"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:id="@+id/tvParticipants"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    tools:text="120 Participants"/>
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/buttonDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/stroke_soft"
            app:layout_constraintTop_toBottomOf="@id/infoContainer"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEdit"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/transparent"
            android:text="Edit Event"
            android:textAllCaps="false"
            android:textColor="@color/on_surface"
            app:cornerRadius="10dp"
            app:strokeColor="@color/stroke_medium"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/buttonDivider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            app:layout_constraintHorizontal_weight="1"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="@android:color/transparent"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="@color/error"
            app:cornerRadius="10dp"
            app:strokeColor="@color/error"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/buttonDivider"
            app:layout_constraintStart_toEndOf="@id/btnEdit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
